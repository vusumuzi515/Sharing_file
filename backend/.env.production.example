# Production config for inyatsi.com
# Copy to .env and fill in real values

PORT=3000
NODE_ENV=production
JWT_SECRET=generate-a-strong-random-secret-min-32-characters

# === FILE SERVER – choose one option ===

# Option A: Network file share (Windows SMB or Linux NFS mount)
# Path where Engineering Site Reports, Finance Documents etc. live
FILE_SERVER_ROOT=/mnt/inyatsi-files

# Option B: Nextcloud WebDAV (if using Nextcloud as file server)
# NEXTCLOUD_URL=https://nextcloud.inyatsi.com/remote.php/dav/files/Inyatsi/
# NEXTCLOUD_USERNAME=Inyatsi
# NEXTCLOUD_PASSWORD=your-app-password

# Users file (sync from AD/LDAP or maintain manually)
USERS_FILE=./config/users.json
