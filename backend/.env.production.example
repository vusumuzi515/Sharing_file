# Production config for inyatsi.com
# Copy to .env and fill in real values

PORT=3000
NODE_ENV=production
JWT_SECRET=generate-a-strong-random-secret-min-32-characters

# === FILE SERVER ===
# Path where Engineering Site Reports, Finance Documents etc. live
FILE_SERVER_ROOT=/mnt/inyatsi-files

# Optional: external Windows bridge / auth API
# Use friend’s public ngrok URL when the bridge is on another network, e.g.:
# EXTERNAL_AUTH_URL=https://xxxx.ngrok-free.app
# EXTERNAL_AUTH_URL=http://server-ip:5200
# EXTERNAL_AUTH_FALLBACK_TO_LOCAL=true
# REMOTE_API_BEARER_TOKEN=windows-bridge-local
# Only departments from bridge / EXTERNAL_AUTH_URL (omit local inyatsi-config / WebDAV scan)
# REMOTE_DEPARTMENTS_ONLY=true
# REMOTE_DEPARTMENTS_PATHS=/api/departments?username={username}
# REMOTE_FILES_PATHS=/api/files?department={orgId},/api/files?department={orgId}&username={username}
# ngrok (free tier): same header your dashboard uses; default in server.js is 1
# NGROK_SKIP_BROWSER_WARNING=1

# Users file (sync from AD/LDAP or maintain manually)
USERS_FILE=./config/users.json
