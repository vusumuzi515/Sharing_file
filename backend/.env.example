PORT=3000
# Bind on all interfaces so phones on Wi‑Fi can reach the API (default 0.0.0.0).
# LISTEN_HOST=0.0.0.0
JWT_SECRET=replace-with-strong-secret

# Windows file server root used for actual file reads/writes on the host machine.
# Example:
# FILE_SERVER_ROOT=D:\FileServer\Departments
# FILE_SERVER_ROOT=./file-server

# Optional: portal upload naming if inyatsi-config.json has no "portal" section
# preserve-name | unique-suffix
# PORTAL_UPLOAD_FILE_NAMING=unique-suffix

# Windows bridge API for real Windows users, departments, and ACL-aware file metadata.
# When set, portal tries POST {url}/api/auth/login with the Windows username/password.
# EXTERNAL_AUTH_URL=http://localhost:5200
# EXTERNAL_AUTH_FALLBACK_TO_LOCAL=true
# Static token is fine for the local bridge; the bridge ignores it, but the portal expects one for cache keys.
# REMOTE_API_BEARER_TOKEN=windows-bridge-local
# REMOTE_DEPARTMENTS_PATHS=/api/departments?username={username}
# REMOTE_FILES_PATHS=/api/files?department={orgId}&username={username}
# Optional fixed username for external dashboard routes
# REMOTE_EXTERNAL_USERNAME=t.maseko
# Comma-separated org slugs for x-org-id (GET /api/files). JWT org claims are merged too.
# REMOTE_X_ORG_ID=lidwala,inyatsi-group
# Required by inyatsi-secure-access-api (GET /api/departments).
# REMOTE_X_DEVICE_ID=inyatsi-portal-web
# ngrok free: header value to skip browser warning page
# NGROK_SKIP_BROWSER_WARNING=1
# Optional API key sent to remote API as x-api-key
# REMOTE_API_KEY=

# Optional: persist file activity for restarts (JSON). Max entries (default 2000).
# ACTIVITY_LOG_PATH=./data/activity-log.json
# ACTIVITY_LOG_MAX=2000
