# Node file portal (Express) — always this for the admin UI, never the Windows bridge (:5200).
#
# Local dev: leave unset. Requests go to same origin (e.g. :5173); Vite proxies `/api` → :3000 (see vite.config.js).
# Only set when Node is on another host, e.g.:
# VITE_BACKEND_API_URL=http://localhost:3000
# VITE_BACKEND_API_URL=https://your-node-host.example.com
#
# If YOU host the admin dashboard itself behind ngrok (same *.ngrok-free.app URL as the API),
# keep the default so every fetch() sends the bypass header (ngrok free-tier interstitial).
# Set to 0 only if you are not using ngrok for the dashboard origin.
# VITE_NGROK_SKIP_BROWSER_WARNING=1

# Optional: Python FastAPI (department ACL, NTFS permissions, file counts).
# When set, fetchDepartments() and fetchPathPermissions() use this origin; must accept the same JWT as Node.
# If this points at an ngrok URL (e.g. friend's Windows bridge), the bypass header is applied automatically.
# VITE_DEPARTMENTS_API_URL=http://localhost:8000
# Optional API key header for remote departments API.
# VITE_DEPARTMENTS_API_KEY=

# Windows UNC prefix for ACL checks via Python /api/permissions (e.g. \\\\fileserver\\CompanyShare)
# VITE_ACL_PATH_PREFIX=

# URL of the main portal
# VITE_PORTAL_URL=http://localhost:8081
